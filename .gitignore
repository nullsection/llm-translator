# Downloaded at setup (large / machine-specific) — never commit.
# models/ = Whisper, NLLB, Piper voices, VOICEVOX (fetched by setup)
# vendor/, bin/ = optional vendored wheels / Python / uv for offline builds
/models/
/vendor/
/bin/
/logs/

# Python environment / build artifacts
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
build/
dist_build/

# Ready-to-go bundles live on Releases, not in git (only the docs/script are tracked).
/dist/*.zip
/dist/*.part*

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
